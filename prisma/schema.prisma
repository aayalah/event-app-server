datasource db {
    provider = "postgresql"
    url = env("DATABASE_URL")
}


model User {
    id Int @id @default(autoincrement())
    full_name String @unique @db.VarChar(30)
    email String @unique @db.VarChar(30)
    user_name String @db.VarChar(30)
    password_hash String @db.VarChar(100)
}

generator client {
    provider = "prisma-client"            // Required
    output   = "../src/generated/prisma" 
}


model Event {
    id Int @id @default(autoincrement())
    source String @db.VarChar(30)
    name String @db.VarChar(30)
    url String @db.VarChar(30)
    categories String[]
    venueName String[]
    location Unsupported("geometry")
    venuePostalCode String
    venueCountry String
    venueStateName String
    venueStateCode String
    venueCityName String
    venueAddressLine1 String
    venueAddressLine2 String
}
