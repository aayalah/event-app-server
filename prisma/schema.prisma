datasource db {
    provider = "postgresql"
    url = env("DATABASE_URL")
}


model User {
    id Int @id @default(autoincrement())
    full_name String @unique @db.VarChar(30)
    email String @unique @db.VarChar(30)
    user_name String @db.VarChar(30)
    password_hash String @db.VarChar(100)
    groups Group[]
}

generator client {
    provider = "prisma-client"            // Required
    output   = "../src/generated/prisma" 
}


model Event {
    id Int @id @default(autoincrement())
    source String @db.VarChar(30)
    name String @db.VarChar(30)
    url String @db.VarChar(30)
    categories String[]
    venueName String[]
    location Unsupported("geometry")
    venuePostalCode String
    venueCountry String
    venueStateName String
    venueStateCode String
    venueCityName String
    venueAddressLine1 String
    venueAddressLine2 String
    startDate DateTime?
}


model Group {
    id Int @id @default(autoincrement())
    name String @db.VarChar(50)
    description String? @db.VarChar(255)
    categories String[]
    city String @db.VarChar(50)
    country String @db.VarChar(50)
    users User[]
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}
